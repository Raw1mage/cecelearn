# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
LOG_LEVEL=info

# Model Configuration
MODEL_PATH=./models/mistral-7b-instruct-v0.2.Q4_K_M.gguf
MODEL_TYPE=llama-cpp  # Options: llama-cpp, transformers, vllm
MAX_TOKENS=2048
TEMPERATURE=0.7
TOP_P=0.9
TOP_K=40

# GPU Configuration
USE_GPU=true
GPU_LAYERS=35  # Number of layers to offload to GPU (adjust based on VRAM)
MAIN_GPU=0
TENSOR_SPLIT=None

# Context Settings
CONTEXT_SIZE=4096
BATCH_SIZE=512

# API Security (optional)
API_KEY=your-secret-api-key-here
ENABLE_AUTH=false

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:5500
ALLOW_CREDENTIALS=true

# Performance
THREADS=8
CACHE_SIZE=2048
