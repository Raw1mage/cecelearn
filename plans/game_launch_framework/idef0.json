{
  "diagram_title": "Launch Game via Voice (A0)",
  "node_reference": "A0",
  "activities": [
    {
      "id": "A1",
      "title": "Classify Intent (backend chat)",
      "inputs": ["Child utterance (voice/text)"],
      "controls": ["allIntentEnum (from GAME_REGISTRY)", "gamePromptLines"],
      "outputs": ["{intent, reply}"],
      "mechanisms": ["a1 chat provider"]
    },
    {
      "id": "A2",
      "title": "Resolve Overlay (frontend)",
      "inputs": ["{intent, reply}"],
      "controls": ["overlayForIntent (registry lookup)", "No-silent-fallback rule"],
      "outputs": ["overlayKind | null"],
      "mechanisms": ["useConversation"]
    },
    {
      "id": "A3",
      "title": "Mount Game Overlay",
      "inputs": ["overlayKind"],
      "controls": ["overlayRegistry (kind->component)"],
      "outputs": ["Opened game overlay", "No-op (null)"],
      "mechanisms": ["A1Page", "overlayRegistry"]
    }
  ],
  "arrows": [
    { "id": "AR0", "source": "EXTERNAL", "target": "A1:input", "label": "Child utterance", "type": "input" },
    { "id": "AR1", "source": "A1:output", "target": "A2:input", "label": "{intent, reply}", "type": "input" },
    { "id": "AR2", "source": "A2:output", "target": "A3:input", "label": "overlayKind", "type": "input" },
    { "id": "AR3", "source": "A3:output", "target": "EXTERNAL", "label": "Opened game overlay", "type": "output" }
  ]
}
