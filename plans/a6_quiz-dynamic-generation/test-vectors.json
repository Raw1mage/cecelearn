    "input": { "type": "http_twice", "path": "/api/quiz?subject=math&grade=2年級&count=3" },
    "expected": { "stems_differ_across_runs": true }
  },
  {
    "id": "TV3",
    "requirement": "數學圖解永不畫錯（viz 算式一致）",
