      { "id": "MSG8", "from": "Server", "to": "ApiClient", "label": "{ok:true, puzzle} | {ok:false, error}", "type": "return" },
      { "id": "MSG9", "from": "ApiClient", "to": "A7Page", "label": "puzzle or error", "type": "return" },
      { "id": "MSG10", "from": "A7Page", "to": "Child", "label": "render board+tray (step 2) OR error+retry (step 9)", "type": "event" }
